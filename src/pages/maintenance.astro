---
import MaintenanceLayout from "../layouts/MaintenanceLayout.astro";
---

<MaintenanceLayout>
  <main class="maintenance-page">
    <section class="maintenance-panel" aria-labelledby="maintenance-title">
      <p class="eyebrow">Maintenance</p>
      <h1 id="maintenance-title">
        This page is reserved for short maintenance windows.
      </h1>
      <p>
        The portfolio is designed to stay available. If this page is visible, a
        deployment or content review is in progress.
      </p>
      <a class="button button--primary" href="/">Return to the portfolio</a>
    </section>
  </main>
</MaintenanceLayout>
