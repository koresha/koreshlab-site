---
import BlogIndex from "../components/BlogIndex.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import { blogIndexByLocale } from "../data/i18n";

const lang = "en";
const content = blogIndexByLocale[lang];
---

<Layout lang={lang} title={content.title} description={content.description}>
  <Header lang={lang} />
  <BlogIndex lang={lang} />
  <Footer lang={lang} />
</Layout>
