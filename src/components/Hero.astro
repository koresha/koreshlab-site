---
import {
  portfolioByLocale,
  uiByLocale,
  type Locale,
} from "../data/i18n";

const { lang = "en" } = Astro.props as { lang?: Locale };
const portfolio = portfolioByLocale[lang];
const ui = uiByLocale[lang];
---

<section class="hero" id="home" aria-labelledby="hero-title">
  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="eyebrow">{portfolio.hero.eyebrow}</p>
      <h1 id="hero-title">{portfolio.hero.title}</h1>
      <p class="hero__lead">{portfolio.hero.lead}</p>
      <div class="hero__actions">
        <a class="button button--primary" href="#contact"
          >{portfolio.hero.primaryAction}</a
        >
        <a class="button button--secondary" href="#experience"
          >{portfolio.hero.secondaryAction}</a
        >
      </div>
    </div>

    <aside class="hero__proof" aria-label={ui.operatingPrinciples}>
      {
        portfolio.hero.stats.map((stat) => (
          <div>
            <span class="metric">{stat.value}</span>
            <span class="metric-label">{stat.label}</span>
          </div>
        ))
      }
    </aside>
  </div>
</section>
