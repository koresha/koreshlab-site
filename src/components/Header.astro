---
import {
  localeNames,
  locales,
  navLinksByLocale,
  siteByLocale,
  switchLocalePath,
  uiByLocale,
  type Locale,
} from "../data/i18n";

const { lang = "en" } = Astro.props as { lang?: Locale };
const site = siteByLocale[lang];
const ui = uiByLocale[lang];
const links = navLinksByLocale[lang];
const currentPath = Astro.url.pathname;
---

<a class="skip-link" href="#main">{ui.skip}</a>

<header class="site-header">
  <div class="site-header__inner">
    <a
      href={lang === "fr" ? "/fr/" : "/"}
      class="brand"
      aria-label={`${site.publicName} ${ui.homeAria}`}
    >
      <span class="brand__logo" aria-hidden="true">
        <span class="brand__logo-core">Kore</span>
        <span class="brand__logo-suffix" data-text=".sh">.sh</span>
      </span>
    </a>

    <nav class="desktop-nav" aria-label={ui.primaryNavigation}>
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <div class="header-actions">
      <div class="language-switcher" role="group" aria-label={ui.language}>
        {
          locales.map((locale) => (
            <a
              class:list={["language-option", { "is-active": locale === lang }]}
              href={switchLocalePath(currentPath, locale)}
              aria-current={locale === lang ? "true" : undefined}
              aria-label={localeNames[locale]}
            >
              {locale.toUpperCase()}
            </a>
          ))
        }
      </div>

      <button
        id="themeToggle"
        class="icon-button"
        type="button"
        aria-label={ui.themeToggle}
      >
        <svg
          class="theme-icon theme-icon--light"
          aria-hidden="true"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.7-5.7 1.4-1.4M4.9 19.1l1.4-1.4m0-11.4L4.9 4.9m14.2 14.2-1.4-1.4M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"
          ></path>
        </svg>
        <svg
          class="theme-icon theme-icon--dark"
          aria-hidden="true"
          viewBox="0 0 24 24"
        >
          <path d="M20 15.3A8.3 8.3 0 0 1 8.7 4 7.6 7.6 0 1 0 20 15.3Z"></path>
        </svg>
      </button>
      <button
        id="mobileMenuToggle"
        class="icon-button mobile-menu-button"
        type="button"
        aria-label={ui.openMenu}
        aria-controls="mobileMenu"
        aria-expanded="false"
        data-open-label={ui.openMenu}
        data-close-label={ui.closeMenu}
      >
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobileMenu"
    class="mobile-nav"
    aria-label={ui.mobileNavigation}
    hidden
  >
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
  </nav>
</header>

<script>
  const root = document.documentElement;
  const themeButton = document.getElementById("themeToggle");
  const menuButton = document.getElementById("mobileMenuToggle");
  const mobileMenu = document.getElementById("mobileMenu");

  function setTheme(theme: "light" | "dark") {
    root.classList.add("is-theme-transitioning");
    root.dataset.theme = theme;
    localStorage.setItem("theme", theme);
    window.setTimeout(() => {
      root.classList.remove("is-theme-transitioning");
    }, 260);
  }

  const storedTheme = localStorage.getItem("theme");
  if (storedTheme === "light" || storedTheme === "dark") {
    root.dataset.theme = storedTheme;
  }

  themeButton?.addEventListener("click", () => {
    setTheme(root.dataset.theme === "dark" ? "light" : "dark");
  });

  function setMenu(open: boolean) {
    if (!menuButton || !mobileMenu) return;
    menuButton.setAttribute("aria-expanded", String(open));
    menuButton.setAttribute(
      "aria-label",
      open
        ? menuButton.dataset.closeLabel || "Close menu"
        : menuButton.dataset.openLabel || "Open menu",
    );
    mobileMenu.hidden = !open;
  }

  menuButton?.addEventListener("click", () => {
    setMenu(menuButton.getAttribute("aria-expanded") !== "true");
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenu(false));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenu(false);
  });
</script>
