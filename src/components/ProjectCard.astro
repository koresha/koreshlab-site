---
import { uiByLocale, type Locale } from "../data/i18n";

const { p, lang = "en" } = Astro.props as {
  p: { title: string; summary: string; impact: string; badges: string[] };
  lang?: Locale;
};
const ui = uiByLocale[lang];
---

<article class="panel proof-card">
  <h3>{p.title}</h3>
  <p>{p.summary}</p>
  <p class="proof-card__impact">{p.impact}</p>
  <div class="chip-list" aria-label={ui.relatedCapabilities}>
    {p.badges.map((badge: string) => <span class="chip">{badge}</span>)}
  </div>
</article>
