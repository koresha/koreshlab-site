---
const { id, title, kicker, intro } = Astro.props as {
  id: string;
  title: string;
  kicker?: string;
  intro?: string;
};
---
<section id={id} class="section">
  <div class="container">
    <div class="section-heading">
      {kicker && <p class="eyebrow">{kicker}</p>}
      <h2>{title}</h2>
      {intro && <p>{intro}</p>}
    </div>
    <slot />
  </div>
</section>
