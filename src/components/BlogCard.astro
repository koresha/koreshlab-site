---
import { localizePath, uiByLocale, type Locale } from "../data/i18n";

const { post, lang = "en" } = Astro.props as {
  post: {
    title: string;
    summary: string;
    date: string;
    slug: string;
    tags: string[];
    readTime?: string;
  };
  lang?: Locale;
};
const ui = uiByLocale[lang];
const date = new Date(`${post.date}T00:00:00Z`);
const dateLocale = lang === "fr" ? "fr-FR" : "en-US";
const href = localizePath(lang, `/blog/${post.slug}/`);
---

<article class="panel blog-card">
  <a href={href} aria-label={`${ui.readArticle}: ${post.title}`}>
    <div class="blog-card__meta">
      <time datetime={post.date}>
        {
          date.toLocaleDateString(dateLocale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
      {post.readTime && <span>{post.readTime}</span>}
    </div>
    <h3>{post.title}</h3>
    <p>{post.summary}</p>
    <div class="chip-list" aria-label={ui.articleTopics}>
      {post.tags.map((tag: string) => <span class="chip">{tag}</span>)}
    </div>
    <span class="text-link">{ui.readArticle}</span>
  </a>
</article>
