---
import {
  navLinksByLocale,
  siteByLocale,
  uiByLocale,
  type Locale,
} from "../data/i18n";

const { lang = "en" } = Astro.props as { lang?: Locale };
const site = siteByLocale[lang];
const ui = uiByLocale[lang];
const links = navLinksByLocale[lang].filter(
  (link) => link.label !== "Proof" && link.label !== "Preuves",
);
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <a
        href={lang === "fr" ? "/fr/" : "/"}
        class="brand brand--footer"
        aria-label={`${site.publicName} ${ui.homeAria}`}
      >
        <span class="brand__logo" aria-hidden="true">
          <span class="brand__logo-core">Kore</span>
          <span class="brand__logo-suffix" data-text=".sh">.sh</span>
        </span>
      </a>
      <p>{site.role}</p>
    </div>

    <nav aria-label={ui.footerNavigation}>
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</footer>
